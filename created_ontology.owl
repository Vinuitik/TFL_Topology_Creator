<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/tfl#offersAccessibilityFeature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>offers accessibility feature</rdfs:label>
    <rdfs:comment>Links a station to its available accessibility services (e.g., elevators).</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
    <rdfs:range rdf:resource="http://example.org/tfl#AccessibilityFeature"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#Station">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Station</rdfs:label>
    <rdfs:comment>A designated stopping place for trains.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#Fare">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Fare</rdfs:label>
    <rdfs:comment>The cost associated with a journey.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#isPubliclyFunded">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>is publicly funded</rdfs:label>
    <rdfs:comment>Indicates if the project is financed by government or public taxes.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#InfrastructureProject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#onRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>on route</rdfs:label>
    <rdfs:comment>Links a line segment to its parent route.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#LineSegment"/>
    <rdfs:range rdf:resource="http://example.org/tfl#Route"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Na784b3fa63734040a650b77a215543ed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="Nc91243a088c449a196279bd129646158"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#appliesDuring">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>applies during</rdfs:label>
    <rdfs:comment>Links a fare or a service restriction to a specific time window.</rdfs:comment>
    <rdfs:domain rdf:nodeID="Na784b3fa63734040a650b77a215543ed"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TimeWindow"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasFare">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has fare</rdfs:label>
    <rdfs:comment>Links a journey to the applicable fare object.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Journey"/>
    <rdfs:range rdf:resource="http://example.org/tfl#Fare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#endTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>end time</rdfs:label>
    <rdfs:comment>The conclusion of a time window.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TimeWindow"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#ProjectStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Project Status</rdfs:label>
    <rdfs:comment>The current stage of a project (e.g., Proposed, Under Construction, Completed).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N1893526c12c74b27a7c6d0d0c7cd19d1">
    <rdf:first rdf:resource="http://example.org/tfl#Zone"/>
    <rdf:rest rdf:nodeID="Ne528f98859914f74babd4d23f20407d2"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has zone</rdfs:label>
    <rdfs:comment>Assigns a geographic fare zone to a station or stop.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
    <rdfs:range rdf:resource="http://example.org/tfl#Zone"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#SignificantDisruption">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Significant Disruption</rdfs:label>
    <rdfs:comment>A major event causing widespread impact over time.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#ServiceDisruption"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#endZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>end zone</rdfs:label>
    <rdfs:comment>The fare zone where a journey concludes.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Journey"/>
    <rdfs:range rdf:resource="http://example.org/tfl#Zone"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasTransportMode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has transport mode</rdfs:label>
    <rdfs:comment>Indicates the mode of transport available at an access point (e.g., Tube, Bus).</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransportMode"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#disruptionDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>disruption date</rdfs:label>
    <rdfs:comment>The date and time when a disruption event occurred.</rdfs:comment>
    <rdfs:comment>The date and time when a service disruption occurred.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#ServiceDisruption"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#affectsRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>affects route</rdfs:label>
    <rdfs:comment>Links a service disruption to the specific route it is impacting.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#ServiceDisruption"/>
    <rdfs:range rdf:resource="http://example.org/tfl#Route"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#BusStop">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Bus Stop</rdfs:label>
    <rdfs:comment>A designated place where buses stop for passengers.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N9d85521de9704e32b1c2126ecd064cb3">
    <rdf:first rdf:resource="http://example.org/tfl#TimeWindow"/>
    <rdf:rest rdf:nodeID="Nc45294f535da4d38b9fa9cc2b2cf9411"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#InterchangeStation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Interchange Station</rdfs:label>
    <rdfs:comment>A station where passengers can switch between different lines.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#TrainStation"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N10187f84d75d47abaaf99749fd6bd638">
    <rdf:first rdf:resource="http://example.org/tfl#DisruptionCause"/>
    <rdf:rest rdf:nodeID="Nfeb0d60f77b54a6990f32f090bc927b0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#reachableFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>reachable from</rdfs:label>
    <rdfs:comment>Indicates a station can be reached from another, potentially across multiple segments.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#operationStartTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>operation start time</rdfs:label>
    <rdfs:comment>The time a service begins daily operations.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Route"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#belongsToRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>belongs to route</rdfs:label>
    <rdfs:comment>Links a sequence of stops to the specific route they define.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#RouteStopSequence"/>
    <rdfs:range rdf:resource="http://example.org/tfl#Route"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasStop">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has stop</rdfs:label>
    <rdfs:comment>Links a route to the stations or stops that it serves.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Route"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#DisruptionCause">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Disruption Cause</rdfs:label>
    <rdfs:comment>The underlying reason for a service disruption.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has status</rdfs:label>
    <rdfs:comment>The current operational status of the service during a disruption.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#ServiceDisruption"/>
    <rdfs:range rdf:resource="http://example.org/tfl#DisruptionStatus"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nc59ed40af4524fc583926ef15836101d">
    <rdf:first rdf:resource="http://example.org/tfl#Line"/>
    <rdf:rest rdf:nodeID="Nad5c35e1b41c401a9be2e7162c2d13d5"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N81936d77430c43a893d7e9fef83da893">
    <rdf:first rdf:resource="http://example.org/tfl#RouteStopSequence"/>
    <rdf:rest rdf:nodeID="Nfbc3a219e13240c2aeeb66f6724d3925"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Na54afc9bc01f4c9d951ebd9828338531">
    <rdf:first rdf:resource="http://example.org/tfl#Station"/>
    <rdf:rest rdf:nodeID="N0e59b596ad564e9cb41f34e90e23063e"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#zoneNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>zone number</rdfs:label>
    <rdfs:comment>The identifying number of a fare zone.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Zone"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#isNightService">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>is night service</rdfs:label>
    <rdfs:comment>Indicates if the service is a night-specific variant (e.g., Night Tube).</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Route"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#NightService">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Night Service</rdfs:label>
    <rdfs:comment>A specific service pattern that operates during late-night and early-morning hours.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#ServiceSchedule"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N84aae10816c14730b583380aeb94924a">
    <rdf:first rdf:resource="http://example.org/tfl#AccessibilityFeature"/>
    <rdf:rest rdf:nodeID="N37833f1620b1436db081763ad7d3b70f"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasScheduleType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has schedule type</rdfs:label>
    <rdfs:comment>Links a route or line to its operating schedule category (e.g., 24-hour or Limited).</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Route"/>
    <rdfs:range rdf:resource="http://example.org/tfl#ServiceSchedule"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasProjectStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has project status</rdfs:label>
    <rdfs:comment>Indicates the current lifecycle stage of an infrastructure project.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#InfrastructureProject"/>
    <rdfs:range rdf:resource="http://example.org/tfl#ProjectStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#endPoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>end point</rdfs:label>
    <rdfs:comment>The final station or stop of a specific journey.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Journey"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#startTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>start time</rdfs:label>
    <rdfs:comment>The beginning of a time window.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TimeWindow"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#stopSequenceNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>stop sequence number</rdfs:label>
    <rdfs:comment>The numerical order of a stop within a route.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#RouteStopSequence"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#FareClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Fare Class</rdfs:label>
    <rdfs:comment>The category of fare applicable to a journey.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#PeakFare">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Peak Fare</rdfs:label>
    <rdfs:comment>Higher pricing applied during high-demand morning and evening periods.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#Fare"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasCause">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has cause</rdfs:label>
    <rdfs:comment>The underlying reason for a disruption (e.g., strike, fault).</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#ServiceDisruption"/>
    <rdfs:range rdf:resource="http://example.org/tfl#DisruptionCause"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nc45294f535da4d38b9fa9cc2b2cf9411">
    <rdf:first rdf:resource="http://example.org/tfl#InfrastructureProject"/>
    <rdf:rest rdf:nodeID="N08921032a9a44d8287fb91e4a3a9bed9"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#UnplannedDisruption">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Unplanned Disruption</rdfs:label>
    <rdfs:comment>An unexpected disruption, like a technical fault.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#ServiceDisruption"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#operatingDays">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>operating days</rdfs:label>
    <rdfs:comment>Textual description of the days the service is active (e.g., 'Mon-Fri').</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Route"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#IndustrialAction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Industrial Action</rdfs:label>
    <rdfs:comment>Strikes or labor-related service withdrawals.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#DisruptionCause"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#startZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>start zone</rdfs:label>
    <rdfs:comment>The fare zone where a journey begins.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Journey"/>
    <rdfs:range rdf:resource="http://example.org/tfl#Zone"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#LineSegment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Line Segment</rdfs:label>
    <rdfs:comment>A specific portion of a transport line between two points.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#SpatialThing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N0e59b596ad564e9cb41f34e90e23063e">
    <rdf:first rdf:resource="http://example.org/tfl#Route"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#servedByRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>served by route</rdfs:label>
    <rdfs:comment>Links a station or stop to the routes that pass through it.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
    <rdfs:range rdf:resource="http://example.org/tfl#Route"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nadd6caf346074893a7957650ecb96d6e">
    <rdf:first rdf:resource="http://example.org/tfl#Station"/>
    <rdf:rest rdf:nodeID="Nbd8295f155fb488f9dbc315114c97e1d"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#StopTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Stop Time</rdfs:label>
    <rdfs:comment>The scheduled arrival or departure time at a specific stop.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#RouteStopSequence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Route Stop Sequence</rdfs:label>
    <rdfs:comment>The ordered list of stops that define a specific route.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#Route">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Route</rdfs:label>
    <rdfs:comment>A path or course followed by a public transport service.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#projectBudget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>project budget</rdfs:label>
    <rdfs:comment>The estimated financial cost of the infrastructure project.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#InfrastructureProject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#operationEndTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>operation end time</rdfs:label>
    <rdfs:comment>The time a service ends daily operations.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Route"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#expectedCompletionDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>expected completion date</rdfs:label>
    <rdfs:comment>The anticipated date when the upgrade or expansion will be finished.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#InfrastructureProject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#TwentyFourHourService">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>24-Hour Service</rdfs:label>
    <rdfs:comment>A service that operates continuously throughout a 24-hour period (e.g., Night Tube, 24-hour buses).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#ServiceSchedule"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#TrainStation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Train Station</rdfs:label>
    <rdfs:comment>A station specifically for heavy or light rail services.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#Station"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasSeverity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has severity</rdfs:label>
    <rdfs:comment>The scale of impact a disruption has on the network.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#ServiceDisruption"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#sequenceStop">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>sequence stop</rdfs:label>
    <rdfs:comment>Links a specific position in a route sequence to a transit stop.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#RouteStopSequence"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nfbc3a219e13240c2aeeb66f6724d3925">
    <rdf:first rdf:resource="http://example.org/tfl#ServiceDisruption"/>
    <rdf:rest rdf:nodeID="N10187f84d75d47abaaf99749fd6bd638"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#TimeWindow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Time Window</rdfs:label>
    <rdfs:comment>A defined period of time during the day used for scheduling or fare calculation.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#directlyConnectedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label>directly connected to</rdfs:label>
    <rdfs:comment>Indicates a direct connection between two transit access points (e.g., adjacent stations).</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasPeakPeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has peak period</rdfs:label>
    <rdfs:comment>Links a station or line to its specific peak demand window.</rdfs:comment>
    <rdfs:domain rdf:nodeID="Nac3714f881af4405833d027ad37cbde0"/>
    <rdfs:range rdf:resource="http://example.org/tfl#PeakPeriod"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#isApplicableOnWeekends">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>is applicable on weekends</rdfs:label>
    <rdfs:comment>Indicates if the time window or fare applies on Saturdays and Sundays.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TimeWindow"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#DisruptionStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Disruption Status</rdfs:label>
    <rdfs:comment>The operational state of a line (e.g., Severe Delays).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#longitude">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>longitude</rdfs:label>
    <rdfs:comment>The geographic longitude coordinate of a transit point.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nc91243a088c449a196279bd129646158">
    <rdf:first rdf:resource="http://example.org/tfl#Fare"/>
    <rdf:rest rdf:nodeID="N8009808adbde48778d9a6d49133b4876"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasEndPoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has end point</rdfs:label>
    <rdfs:comment>The ending point of a specific line segment.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#LineSegment"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#ServiceDisruption">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Service Disruption</rdfs:label>
    <rdfs:comment>An event that interferes with normal operation.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#MinorDelays">
    <rdf:type rdf:resource="http://example.org/tfl#DisruptionStatus"/>
    <rdfs:label>Minor Delays</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#Point">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Point</rdfs:label>
    <rdfs:comment>A specific geographic coordinate.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N08921032a9a44d8287fb91e4a3a9bed9">
    <rdf:first rdf:resource="http://example.org/tfl#ProjectStatus"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#OffPeakFare">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Off-Peak Fare</rdfs:label>
    <rdfs:comment>Discounted pricing applied during lower-demand periods.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#Fare"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ne528f98859914f74babd4d23f20407d2">
    <rdf:first rdf:resource="http://example.org/tfl#TransportMode"/>
    <rdf:rest rdf:nodeID="N36fdbbddcfcc4963b6017cc62ca629fd"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#OffPeakPeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Off-Peak Period</rdfs:label>
    <rdfs:comment>Lower-demand travel times where discounted fares typically apply.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#TimeWindow"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasStartPoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has start point</rdfs:label>
    <rdfs:comment>The beginning point of a specific line segment.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#LineSegment"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#affectsStop">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>affects stop</rdfs:label>
    <rdfs:comment>Links a service disruption to a specific station or stop.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#ServiceDisruption"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#TechnicalFault">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Technical Fault</rdfs:label>
    <rdfs:comment>Mechanical or electronic equipment failure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#DisruptionCause"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N37833f1620b1436db081763ad7d3b70f">
    <rdf:first rdf:resource="http://example.org/tfl#Fare"/>
    <rdf:rest rdf:nodeID="Nd673ebe7c4a64f38b1313fd7e82346fc"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nad5c35e1b41c401a9be2e7162c2d13d5">
    <rdf:first rdf:resource="http://example.org/tfl#Station"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#targetsInfrastructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>targets infrastructure</rdfs:label>
    <rdfs:comment>Links a project to the specific station or line being improved.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#InfrastructureProject"/>
    <rdfs:range rdf:nodeID="Nf5d652b5f6e8404fbf723ae99c916d50"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N467b4f44b46d48008e0d3797ace07f92">
    <rdf:first rdf:resource="http://example.org/tfl#ServiceSchedule"/>
    <rdf:rest rdf:nodeID="N9d85521de9704e32b1c2126ecd064cb3"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#SevereDelays">
    <rdf:type rdf:resource="http://example.org/tfl#DisruptionStatus"/>
    <rdfs:label>Severe Delays</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#InfrastructureProject">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Infrastructure Project</rdfs:label>
    <rdfs:comment>A planned endeavor to improve or expand the transport network.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#ServiceSchedule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Service Schedule</rdfs:label>
    <rdfs:comment>The timeframe and frequency under which a transport service operates.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#TransitAccessPoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Transit Access Point</rdfs:label>
    <rdfs:comment>A physical location where passengers enter or exit the system.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#SpatialThing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#SignalFailure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Signal Failure</rdfs:label>
    <rdfs:comment>A specific technical fault in the signaling system.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#TechnicalFault"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#Line">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Line</rdfs:label>
    <rdfs:comment>A named transport line, such as a specific Tube or DLR line.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#Route"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N5b8f2672f72d4b46a1d92bd644157c52">
    <rdf:first rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
    <rdf:rest rdf:nodeID="N1893526c12c74b27a7c6d0d0c7cd19d1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#PlannedDisruption">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Planned Disruption</rdfs:label>
    <rdfs:comment>A disruption scheduled in advance, like maintenance.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#ServiceDisruption"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#StationUpgrade">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Station Upgrade</rdfs:label>
    <rdfs:comment>Improvements to existing stations, such as adding step-free access or increasing capacity.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#InfrastructureProject"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N8413e51e71fe437ba534472f80ca90d7">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="N654e1ffe200c4fb2baa34a00ddabd189"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N36fdbbddcfcc4963b6017cc62ca629fd">
    <rdf:first rdf:resource="http://example.org/tfl#Journey"/>
    <rdf:rest rdf:nodeID="N84aae10816c14730b583380aeb94924a"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#LineExpansion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Line Expansion</rdfs:label>
    <rdfs:comment>The construction of new tracks or the extension of an existing line to new areas.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#InfrastructureProject"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#EngineeringWorks">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Engineering Works</rdfs:label>
    <rdfs:comment>Planned maintenance or construction on infrastructure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#DisruptionCause"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#GoodService">
    <rdf:type rdf:resource="http://example.org/tfl#DisruptionStatus"/>
    <rdfs:label>Good Service</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N039b5459049447e382d49d7651940656">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="Nc59ed40af4524fc583926ef15836101d"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#openingDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>opening date</rdfs:label>
    <rdfs:comment>The historical date a line or station first opened to the public.</rdfs:comment>
    <rdfs:domain rdf:nodeID="N039b5459049447e382d49d7651940656"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#RollingStockIssue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Rolling Stock Issue</rdfs:label>
    <rdfs:comment>Mechanical problems with the vehicles (trains/buses).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#TechnicalFault"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#startPoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>start point</rdfs:label>
    <rdfs:comment>The station or stop where a journey begins.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Journey"/>
    <rdfs:range rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#AccessibilityFeature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Accessibility Feature</rdfs:label>
    <rdfs:comment>Physical features or services providing access (e.g., step-free access).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>has name</rdfs:label>
    <rdfs:comment>the human-readable name of an entity (e.g., station name, line name).</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#BusRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Bus Route</rdfs:label>
    <rdfs:comment>A specific numbered route followed by a bus service.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#Route"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#hasOffPeakPeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has off-peak period</rdfs:label>
    <rdfs:comment>Links a station or line to its specific off-peak window.</rdfs:comment>
    <rdfs:domain rdf:nodeID="N8413e51e71fe437ba534472f80ca90d7"/>
    <rdfs:range rdf:resource="http://example.org/tfl#OffPeakPeriod"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#TransportMode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Transport Mode</rdfs:label>
    <rdfs:comment>The type of vehicle used (e.g., Tube, Bus, DLR).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nbd8295f155fb488f9dbc315114c97e1d">
    <rdf:first rdf:resource="http://example.org/tfl#Route"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nd673ebe7c4a64f38b1313fd7e82346fc">
    <rdf:first rdf:resource="http://example.org/tfl#Route"/>
    <rdf:rest rdf:nodeID="N81936d77430c43a893d7e9fef83da893"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nac3714f881af4405833d027ad37cbde0">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="Nadd6caf346074893a7957650ecb96d6e"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#LimitedService">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Limited Service</rdfs:label>
    <rdfs:comment>A service with restricted operating hours, such as daytime-only or peak-hour only services.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#ServiceSchedule"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N8009808adbde48778d9a6d49133b4876">
    <rdf:first rdf:resource="http://example.org/tfl#Route"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nfeb0d60f77b54a6990f32f090bc927b0">
    <rdf:first rdf:resource="http://example.org/tfl#DisruptionStatus"/>
    <rdf:rest rdf:nodeID="N467b4f44b46d48008e0d3797ace07f92"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#SpatialThing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Spatial Thing</rdfs:label>
    <rdfs:comment>Anything with a physical location or spatial extent.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#PeakPeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Peak Period</rdfs:label>
    <rdfs:comment>High-demand travel times (e.g., morning and evening rush hours) where higher fares often apply.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/tfl#TimeWindow"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#PartSuspended">
    <rdf:type rdf:resource="http://example.org/tfl#DisruptionStatus"/>
    <rdfs:label>Part Suspended</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#Zone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Zone</rdfs:label>
    <rdfs:comment>A geographic area used for fare calculation.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nf5d652b5f6e8404fbf723ae99c916d50">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="Na54afc9bc01f4c9d951ebd9828338531"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N4401222ef9dd4f7185ed07c743c9d83a">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
