  </rdf:Description>
  <rdf:Description rdf:nodeID="N9305cb8a32354cb29f7dd779fa0dbe59">
    <rdf:first rdf:resource="http://example.org/tfl#Route"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N654e1ffe200c4fb2baa34a00ddabd189">
    <rdf:first rdf:resource="http://example.org/tfl#Station"/>
    <rdf:rest rdf:nodeID="N9305cb8a32354cb29f7dd779fa0dbe59"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#fareCost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>fare cost</rdfs:label>
    <rdfs:comment>The monetary price of a fare.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#Fare"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#latitude">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>latitude</rdfs:label>
    <rdfs:comment>The geographic latitude coordinate of a transit point.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/tfl#TransitAccessPoint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/tfl#Journey">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Journey</rdfs:label>
    <rdfs:comment>A specific instance of travel from an origin to a destination.</rdfs:comment>
  </rdf:Description>
</rdf:RDF>
