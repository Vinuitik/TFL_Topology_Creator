@prefix : <urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#> .
@prefix gtfs: <http://vocab.gtfs.org/terms#> .
@prefix local: <http://example.org/tfl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/tfl> a owl:Ontology .

local:Line rdfs:subClassOf gtfs:Route .

local:Route rdfs:subClassOf gtfs:Route .

local:TransitAccessPoint rdfs:subClassOf local:Stop .

local:Zone a owl:Class ;
    owl:equivalentClass gtfs:Zone .

local:endStation rdfs:subPropertyOf gtfs:destinationStop .

local:locatedInZone a owl:ObjectProperty ;
    owl:equivalentProperty gtfs:zone .

local:servesLine rdfs:subPropertyOf gtfs:route .

local:startStation rdfs:subPropertyOf gtfs:originStop .

