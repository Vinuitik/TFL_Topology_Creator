ns1:directlyConnectedTo a owl:ObjectProperty ;
    rdfs:label "connects" ;
    rdfs:comment "Indicates the relationship between two entities where one is directly linked to another by a service or interchange.",
        "Indicates the relationship between two transport entities sharing a common route or service.",
        "Indicates the relationship between two transport entities where one is connected to another by a service or route." .

ns1:isScheduledService a owl:DatatypeProperty ;
    rdfs:label "scheduled service",
        "scheduled-service" ;
    rdfs:comment "A transportation arrangement with specific times and routes, typically used for public transit or scheduled travel.",
        "Describes a transport service with specific times and frequencies." .

ns1:lineLength a owl:DatatypeProperty ;
    rdfs:label "Length" ;
    rdfs:comment "Represents the measurement of distance in transport systems, such as vehicles or routes." .

ns1:locatedInZone a owl:ObjectProperty ;
    rdfs:label "located" ;
    rdfs:comment "Indicates the position of an entity within a transport network, such as a bus stop or train station." .

ns1:operatedBy a owl:ObjectProperty ;
    rdfs:label "Operating Item" ;
    rdfs:comment "A transport vehicle, train, bus, etc., that is used for passenger or freight transportation." .

ns1:operates a owl:ObjectProperty ;
    rdfs:label "operator" ;
    rdfs:comment "A person, company, or organization responsible for managing and operating a transport service.",
        "A person, company, or organization responsible for managing and operating transport services.",
        "Designates an entity responsible for managing and operating transport services, including routes, schedules, and vehicles." .

ns1:rel_architecture a owl:ObjectProperty ;
    rdfs:label "architectural design" ;
    rdfs:comment "Refers to the planning, layout, and construction details of a building or structure." .

ns1:rel_author a owl:ObjectProperty ;
    rdfs:label "Author" ;
    rdfs:comment "A person who writes books, including novels and short stories." .

ns1:rel_awarded a owl:ObjectProperty ;
    rdfs:label "awarded" ;
    rdfs:comment "Designates an award given to a person, organization, or entity for achievement or distinction." .

ns1:rel_bordering a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "bordering" ;
    rdfs:comment "Indicates proximity to another location, often used in transportation networks for neighboring stations or stops." .

ns1:rel_contains a owl:ObjectProperty ;
    rdfs:label "contains part" ;
    rdfs:comment "Indicates one element is included within another in a transport system." .

ns1:rel_country a owl:ObjectProperty ;
    rdfs:label "country" ;
    rdfs:comment "A geopolitical entity consisting of one or more states, typically delineated by a nation's borders and sovereignty." .

ns1:rel_crowd a owl:ObjectProperty ;
    rdfs:label "Crowd" ;
    rdfs:comment "Refers to the number of people present in a transport area, indicating congestion or density." .

ns1:rel_differentfrom a owl:ObjectProperty ;
    rdfs:label "different",
        "different from" ;
    rdfs:comment "Indicates that two entities have distinct characteristics, properties, or locations without being identical.",
        "Indicates two things being distinct from each other." .

ns1:rel_disruption a owl:ObjectProperty ;
    rdfs:label "disruption" ;
    rdfs:comment "Indicates an interruption in transport services, such as delays, cancellations, or service changes." .

ns1:rel_end_time a owl:DatatypeProperty ;
    rdfs:label "End Time" ;
    rdfs:comment "Represents the final departure or arrival time of a transport journey." .

ns1:rel_entry_point a owl:DatatypeProperty ;
    rdfs:label "Entry Point" ;
    rdfs:comment "A designated location where passengers enter a transport system, often marked by signage or physical barriers." .

ns1:rel_followed_by a owl:ObjectProperty ;
    rdfs:label "follows" ;
    rdfs:comment "Indicates the sequence of events, actions, or services that occur in a transport network.",
        "Indicates the sequence of events, actions, or steps in a transport process.",
        "Indicates the sequence of events, items, or steps in a process or timeline." .

ns1:rel_formed_location a owl:ObjectProperty ;
    rdfs:label "formed location" ;
    rdfs:comment "Describes a place where two or more entities are joined together, often for administrative purposes." .

ns1:rel_inception a owl:DatatypeProperty ;
    rdfs:label "inception" ;
    rdfs:comment "A process in which an entity is formed, typically involving the combination of elements or characteristics.",
        "A process in which something is formed, especially of an idea or concept within a person's mind.",
        "A process in which something is formed, especially of an idea or concept." .

ns1:rel_industry a owl:ObjectProperty ;
    rdfs:label "industries" ;
    rdfs:comment "A category of economic activity involving production, processing, and distribution of goods or services." .

ns1:rel_instance_of a owl:ObjectProperty ;
    rdfs:label "instance of" ;
    rdfs:comment "Describes an entity's classification within a specific context, such as being a type or subclass." .

ns1:rel_list a owl:ObjectProperty ;
    rdfs:label "List" ;
    rdfs:comment "A collection of items presented in order, typically for reference or presentation." .

ns1:rel_manufacturer a owl:ObjectProperty ;
    rdfs:label "manufacturer" ;
    rdfs:comment "A company responsible for producing vehicles, trains, ships, etc., which are used in transport systems." .

ns1:rel_material a owl:ObjectProperty ;
    rdfs:label "material" ;
    rdfs:comment "Describes the substance of an item, used in transport contexts such as vehicle components or cargo.",
        "Describes the substance used to create an item, such as a vehicle or component." .

ns1:rel_member a owl:ObjectProperty ;
    rdfs:label "Member" ;
    rdfs:comment "A participant in an organization, group, or community." .

ns1:rel_modified a owl:ObjectProperty ;
    rdfs:label "modified" ;
    rdfs:comment "Changes an existing instance of something, typically to update its properties or state." .

ns1:rel_named_after a owl:ObjectProperty ;
    rdfs:label "named after" ;
    rdfs:comment "Refers to an entity being named in honor of another, often a person or event." .

ns1:rel_opposite a owl:ObjectProperty ;
    rdfs:label "opposite of" ;
    rdfs:comment "Relates two locations where one is located on the opposite side of a building or structure." .

ns1:rel_owned_by a owl:ObjectProperty ;
    rdfs:label "Owner",
        "owns" ;
    rdfs:comment "Designates the entity responsible for managing and operating a transport asset.",
        "Indicates ownership of an entity by another entity in the transport network." .

ns1:rel_parent_organization a owl:ObjectProperty ;
    rdfs:label "organization" ;
    rdfs:comment "A legal entity responsible for managing and operating transport services." .

ns1:rel_performer a owl:ObjectProperty ;
    rdfs:label "performer" ;
    rdfs:comment "A person who engages in an activity, such as singing, acting, or playing music." .

ns1:rel_point_in_time a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "point in time" ;
