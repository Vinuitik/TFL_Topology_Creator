:startZone rdf:type owl:ObjectProperty ;
           rdfs:domain <http://webprotege.stanford.edu/R8gcQaW839Or2hVYprhpSK8> ;
           rdfs:range <http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg> .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#belongsToRoute
:belongsToRoute rdf:type owl:ObjectProperty ;
                rdfs:domain :RouteStopSequence ;
                rdfs:range <http://webprotege.stanford.edu/RIfSnBzsdC7fyIHQcX6Erd> ;
                rdfs:label "belongsToRoute" .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#sequenceStop
:sequenceStop rdf:type owl:ObjectProperty ;
              rdfs:domain :RouteStopSequence ;
              rdfs:range :TransitAccessPoint ;
              rdfs:label "sequenceStop" .


#################################################################
#    Data properties
#################################################################

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#hasName
:hasName rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:string ;
         rdfs:label "hasName" .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#fareCost
:fareCost rdf:type owl:DatatypeProperty ;
          rdfs:domain <http://webprotege.stanford.edu/RFQBoIMyODKarwW9fBl0aS> ;
          rdfs:range xsd:decimal ;
          rdfs:label "fareCost" .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#zoneNumber
:zoneNumber rdf:type owl:DatatypeProperty ;
            rdfs:domain <http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg> ;
            rdfs:range xsd:integer ;
            rdfs:label "zoneNumber" .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#stopSequenceNumber
:stopSequenceNumber rdf:type owl:DatatypeProperty ;
                    rdfs:domain :RouteStopSequence ;
                    rdfs:range xsd:integer ;
                    rdfs:label "stopSequenceNumber" .


#################################################################
#    Classes
#################################################################

###  http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg
<http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg> rdf:type owl:Class ;
                                                         rdfs:label "Zone" .


###  http://webprotege.stanford.edu/R7mQXjcxy79h9g8J1fC0tjV
<http://webprotege.stanford.edu/R7mQXjcxy79h9g8J1fC0tjV> rdf:type owl:Class ;
                                                         rdfs:label "TransportMode" .


###  http://webprotege.stanford.edu/R8gcQaW839Or2hVYprhpSK8
<http://webprotege.stanford.edu/R8gcQaW839Or2hVYprhpSK8> rdf:type owl:Class ;
                                                         rdfs:label "Journey" .


###  http://webprotege.stanford.edu/R8suZp8urh3QUp7Gjq7I9vS
<http://webprotege.stanford.edu/R8suZp8urh3QUp7Gjq7I9vS> rdf:type owl:Class ;
                                                         rdfs:label "AccessibilityFeature" .


###  http://webprotege.stanford.edu/R9TCSglVMKeAj22qlxYUozU
<http://webprotege.stanford.edu/R9TCSglVMKeAj22qlxYUozU> rdf:type owl:Class ;
                                                         rdfs:subClassOf :TransitAccessPoint ;
                                                         rdfs:label "BusStop" .


###  http://webprotege.stanford.edu/RDEVnVTugRbS0jlPdGiumAj
<http://webprotege.stanford.edu/RDEVnVTugRbS0jlPdGiumAj> rdf:type owl:Class ;
                                                         rdfs:subClassOf <http://webprotege.stanford.edu/RIfSnBzsdC7fyIHQcX6Erd> ;
                                                         rdfs:label "Line" .


###  http://webprotege.stanford.edu/RFQBoIMyODKarwW9fBl0aS
<http://webprotege.stanford.edu/RFQBoIMyODKarwW9fBl0aS> rdf:type owl:Class ;
                                                        rdfs:label "Fare" .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#PeakFare
:PeakFare rdf:type owl:Class ;
          rdfs:subClassOf <http://webprotege.stanford.edu/RFQBoIMyODKarwW9fBl0aS> ;
          rdfs:label "PeakFare" .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#OffPeakFare
:OffPeakFare rdf:type owl:Class ;
             rdfs:subClassOf <http://webprotege.stanford.edu/RFQBoIMyODKarwW9fBl0aS> ;
             rdfs:label "OffPeakFare" .


###  http://webprotege.stanford.edu/RIfSnBzsdC7fyIHQcX6Erd
<http://webprotege.stanford.edu/RIfSnBzsdC7fyIHQcX6Erd> rdf:type owl:Class ;
                                                        rdfs:label "Route" .


###  http://webprotege.stanford.edu/TrainStation
<http://webprotege.stanford.edu/TrainStation> rdf:type owl:Class ;
                                              rdfs:subClassOf :TransitAccessPoint ;
                                              rdfs:label "TrainStation" .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#InterchangeStation
:InterchangeStation rdf:type owl:Class ;
                    rdfs:subClassOf <http://webprotege.stanford.edu/TrainStation> ;
                    rdfs:label "InterchangeStation" .



###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#TransitAccessPoint
:TransitAccessPoint rdf:type owl:Class ;
                    rdfs:label "TransitAccessPoint" .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#RouteStopSequence
:RouteStopSequence rdf:type owl:Class ;
                   rdfs:label "RouteStopSequence" .


#################################################################
#    External Ontology Mappings
#################################################################

<http://webprotege.stanford.edu/RIfSnBzsdC7fyIHQcX6Erd> owl:equivalentClass gtfs:Route .
<http://webprotege.stanford.edu/R8gcQaW839Or2hVYprhpSK8> owl:equivalentClass gtfs:Trip .
:TransitAccessPoint owl:equivalentClass gtfs:Stop ;
                    rdfs:subClassOf geo:SpatialThing .
<http://webprotege.stanford.edu/TrainStation> rdfs:subClassOf gtfs:Station .
:RouteStopSequence owl:equivalentClass gtfs:StopTime .
<http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg> owl:equivalentClass gtfs:Zone .
<http://webprotege.stanford.edu/RFQBoIMyODKarwW9fBl0aS> rdfs:subClassOf gtfs:FareClass .

:hasZone owl:equivalentProperty gtfs:zone .
:stopSequenceNumber owl:equivalentProperty gtfs:stopSequence .
:sequenceStop owl:equivalentProperty gtfs:stop .
:hasName rdfs:subPropertyOf gtfs:shortName .

:latitude rdf:type owl:DatatypeProperty ;
          rdfs:domain :TransitAccessPoint ;
          rdfs:range xsd:decimal ;
          owl:equivalentProperty geo:lat .

:longitude rdf:type owl:DatatypeProperty ;
           rdfs:domain :TransitAccessPoint ;
           rdfs:range xsd:decimal ;
           owl:equivalentProperty geo:long .

#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :TransitAccessPoint
                <http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg>
                <http://webprotege.stanford.edu/R7mQXjcxy79h9g8J1fC0tjV>
                <http://webprotege.stanford.edu/R8gcQaW839Or2hVYprhpSK8>
                <http://webprotege.stanford.edu/R8suZp8urh3QUp7Gjq7I9vS>
                <http://webprotege.stanford.edu/RFQBoIMyODKarwW9fBl0aS>
                <http://webprotege.stanford.edu/RIfSnBzsdC7fyIHQcX6Erd>
                :RouteStopSequence
              )
] .


#################################################################
#    Individuals
#################################################################

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#Zone1
:Zone1 rdf:type owl:NamedIndividual ,
                <http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg> ;
       :zoneNumber 1 .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#StepFreeAccess
:StepFreeAccess rdf:type owl:NamedIndividual ,
                         <http://webprotege.stanford.edu/R8suZp8urh3QUp7Gjq7I9vS> ;
                :hasName "Step-Free Access"^^xsd:string .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#VictoriaStation
:VictoriaStation rdf:type owl:NamedIndividual ,
                          <http://webprotege.stanford.edu/TrainStation> ;
                 :hasName "Victoria Station"^^xsd:string ;
                 :hasZone :Zone1 ;
                 :offersAccessibilityFeature :StepFreeAccess ;
                 :latitude 51.4952 ;
                 :longitude -0.1439 .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#OxfordCircusStation
:OxfordCircusStation rdf:type owl:NamedIndividual ,
                              <http://webprotege.stanford.edu/TrainStation> ,
                              :InterchangeStation ;
                     :hasName "Oxford Circus Station"^^xsd:string ;
                     :hasZone :Zone1 .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#VictoriaLine
:VictoriaLine rdf:type owl:NamedIndividual ,
                       <http://webprotege.stanford.edu/RDEVnVTugRbS0jlPdGiumAj> ;
              :hasName "Victoria Line"^^xsd:string ;
              :hasStop :VictoriaStation ,
                       :GreenParkStation ,
                       :OxfordCircusStation .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#Bus25
:Bus25 rdf:type owl:NamedIndividual ,
                <http://webprotege.stanford.edu/RIfSnBzsdC7fyIHQcX6Erd> ;
       :hasName "Bus Route 25"^^xsd:string .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#OxfordCircusBusStop
:OxfordCircusBusStop rdf:type owl:NamedIndividual ,
                              <http://webprotege.stanford.edu/R9TCSglVMKeAj22qlxYUozU> ;
                     :hasName "Oxford Circus Bus Stop"^^xsd:string ;
                     :hasZone :Zone1 .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#HolbornBusStop
:HolbornBusStop rdf:type owl:NamedIndividual ,
                         <http://webprotege.stanford.edu/R9TCSglVMKeAj22qlxYUozU> ;
                :hasName "Holborn Bus Stop"^^xsd:string ;
                :hasZone :Zone1 .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#Bus25_Seq1
:Bus25_Seq1 rdf:type owl:NamedIndividual ,
                     :RouteStopSequence ;
            :belongsToRoute :Bus25 ;
            :sequenceStop :OxfordCircusBusStop ;
            :stopSequenceNumber 1 .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#Bus25_Seq2
:Bus25_Seq2 rdf:type owl:NamedIndividual ,
                     :RouteStopSequence ;
            :belongsToRoute :Bus25 ;
            :sequenceStop :HolbornBusStop ;
            :stopSequenceNumber 2 .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#PeakFare1
:PeakFare1 rdf:type owl:NamedIndividual ,
                    :PeakFare ;
           :fareCost 3.50 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#JourneyVicToOx
:JourneyVicToOx rdf:type owl:NamedIndividual ,
                         <http://webprotege.stanford.edu/R8gcQaW839Or2hVYprhpSK8> ;
                :startStation :VictoriaStation ;
                :endStation :OxfordCircusStation ;
                :startZone :Zone1 ;
                :endZone :Zone1 ;
                :hasFare :PeakFare1 .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#CentralLine
:CentralLine rdf:type owl:NamedIndividual ,
                      <http://webprotege.stanford.edu/RDEVnVTugRbS0jlPdGiumAj> ;
             :hasName "Central Line"^^xsd:string ;
             :hasStop :OxfordCircusStation , :HolbornStation , :BankStation , :StratfordStation .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#HolbornStation
:HolbornStation rdf:type owl:NamedIndividual ,
                         <http://webprotege.stanford.edu/TrainStation> ;
                :hasName "Holborn Station"^^xsd:string ;
                :hasZone :Zone1 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#VicSeq1
:VicSeq1 rdf:type owl:NamedIndividual , :RouteStopSequence ;
         :belongsToRoute :VictoriaLine ;
         :sequenceStop :VictoriaStation ;
         :stopSequenceNumber 1 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#VicSeqGreenPark
:VicSeqGreenPark rdf:type owl:NamedIndividual , :RouteStopSequence ;
                 :belongsToRoute :VictoriaLine ;
                 :sequenceStop :GreenParkStation ;
                 :stopSequenceNumber 2 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#VicSeq2
:VicSeq2 rdf:type owl:NamedIndividual , :RouteStopSequence ;
         :belongsToRoute :VictoriaLine ;
         :sequenceStop :OxfordCircusStation ;
         :stopSequenceNumber 3 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#CenSeq1
:CenSeq1 rdf:type owl:NamedIndividual , :RouteStopSequence ;
         :belongsToRoute :CentralLine ;
         :sequenceStop :OxfordCircusStation ;
         :stopSequenceNumber 1 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#CenSeq2
:CenSeq2 rdf:type owl:NamedIndividual , :RouteStopSequence ;
         :belongsToRoute :CentralLine ;
         :sequenceStop :HolbornStation ;
         :stopSequenceNumber 2 .


###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#OffPeakFare1
:OffPeakFare1 rdf:type owl:NamedIndividual , :OffPeakFare ;
              :fareCost 2.50 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#JourneyVicToOxOffPeak
:JourneyVicToOxOffPeak rdf:type owl:NamedIndividual ,
                         <http://webprotege.stanford.edu/R8gcQaW839Or2hVYprhpSK8> ;
                :startStation :VictoriaStation ;
                :endStation :OxfordCircusStation ;
                :startZone :Zone1 ;
                :endZone :Zone1 ;
                :hasFare :OffPeakFare1 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#Zone2
:Zone2 rdf:type owl:NamedIndividual ,
                <http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg> ;
       :zoneNumber 2 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#Zone3
:Zone3 rdf:type owl:NamedIndividual ,
                <http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg> ;
       :zoneNumber 3 .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#EscalatorAccess
:EscalatorAccess rdf:type owl:NamedIndividual ,
