            :hasName "WiFi Access"^^xsd:string .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#GreenParkStation
:GreenParkStation rdf:type owl:NamedIndividual ,
                           <http://webprotege.stanford.edu/TrainStation> ,
                           :InterchangeStation ;
                  :hasName "Green Park Station"^^xsd:string ;
                  :hasZone :Zone1 ;
                  :offersAccessibilityFeature :StepFreeAccess , :EscalatorAccess .

###  urn:webprotege:ontology:c73d2ce1-09f8-451b-b6fd-d3ba1ee14c49#WaterlooStation
:WaterlooStation rdf:type owl:NamedIndividual ,
