:hasZone rdf:type owl:ObjectProperty ;
         rdfs:domain <http://webprotege.stanford.edu/TrainStation> ;
         rdfs:range <http://webprotege.stanford.edu/R7cZlQsX1sMesyLmlHKw2lg> .


