@prefix ex: <http://example.org/tfl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:BusRoute a owl:Class ;
    rdfs:label "Bus Route" ;
    rdfs:comment "A specific numbered route followed by a bus service." ;
    rdfs:subClassOf ex:Route .

ex:BusStop a owl:Class ;
    rdfs:label "Bus Stop" ;
    rdfs:comment "A designated place where buses stop for passengers." ;
    rdfs:subClassOf ex:TransitAccessPoint .

ex:EngineeringWorks a owl:Class ;
    rdfs:label "Engineering Works" ;
    rdfs:comment "Planned maintenance or construction on infrastructure." ;
    rdfs:subClassOf ex:DisruptionCause .

ex:FareClass a owl:Class ;
    rdfs:label "Fare Class" ;
    rdfs:comment "The category of fare applicable to a journey." .

ex:GoodService a ex:DisruptionStatus ;
    rdfs:label "Good Service" .

ex:IndustrialAction a owl:Class ;
    rdfs:label "Industrial Action" ;
    rdfs:comment "Strikes or labor-related service withdrawals." ;
    rdfs:subClassOf ex:DisruptionCause .

ex:InterchangeStation a owl:Class ;
    rdfs:label "Interchange Station" ;
    rdfs:comment "A station where passengers can switch between different lines." ;
    rdfs:subClassOf ex:TrainStation .

ex:LimitedService a owl:Class ;
    rdfs:label "Limited Service" ;
    rdfs:comment "A service with restricted operating hours, such as daytime-only or peak-hour only services." ;
    rdfs:subClassOf ex:ServiceSchedule .

ex:LineExpansion a owl:Class ;
    rdfs:label "Line Expansion" ;
    rdfs:comment "The construction of new tracks or the extension of an existing line to new areas." ;
    rdfs:subClassOf ex:InfrastructureProject .

ex:MinorDelays a ex:DisruptionStatus ;
    rdfs:label "Minor Delays" .

ex:NightService a owl:Class ;
    rdfs:label "Night Service" ;
    rdfs:comment "A specific service pattern that operates during late-night and early-morning hours." ;
    rdfs:subClassOf ex:ServiceSchedule .

ex:OffPeakFare a owl:Class ;
    rdfs:label "Off-Peak Fare" ;
    rdfs:comment "Discounted pricing applied during lower-demand periods." ;
    rdfs:subClassOf ex:Fare .

ex:PartSuspended a ex:DisruptionStatus ;
    rdfs:label "Part Suspended" .

ex:PeakFare a owl:Class ;
    rdfs:label "Peak Fare" ;
    rdfs:comment "Higher pricing applied during high-demand morning and evening periods." ;
    rdfs:subClassOf ex:Fare .

ex:PlannedDisruption a owl:Class ;
    rdfs:label "Planned Disruption" ;
    rdfs:comment "A disruption scheduled in advance, like maintenance." ;
    rdfs:subClassOf ex:ServiceDisruption .

ex:Point a owl:Class ;
    rdfs:label "Point" ;
    rdfs:comment "A specific geographic coordinate." .

ex:RollingStockIssue a owl:Class ;
    rdfs:label "Rolling Stock Issue" ;
    rdfs:comment "Mechanical problems with the vehicles (trains/buses)." ;
    rdfs:subClassOf ex:TechnicalFault .

ex:SevereDelays a ex:DisruptionStatus ;
    rdfs:label "Severe Delays" .

ex:SignalFailure a owl:Class ;
    rdfs:label "Signal Failure" ;
    rdfs:comment "A specific technical fault in the signaling system." ;
    rdfs:subClassOf ex:TechnicalFault .

ex:SignificantDisruption a owl:Class ;
    rdfs:label "Significant Disruption" ;
    rdfs:comment "A major event causing widespread impact over time." ;
    rdfs:subClassOf ex:ServiceDisruption .

ex:StationUpgrade a owl:Class ;
    rdfs:label "Station Upgrade" ;
    rdfs:comment "Improvements to existing stations, such as adding step-free access or increasing capacity." ;
    rdfs:subClassOf ex:InfrastructureProject .

ex:StopTime a owl:Class ;
    rdfs:label "Stop Time" ;
    rdfs:comment "The scheduled arrival or departure time at a specific stop." .

ex:TwentyFourHourService a owl:Class ;
    rdfs:label "24-Hour Service" ;
    rdfs:comment "A service that operates continuously throughout a 24-hour period (e.g., Night Tube, 24-hour buses)." ;
    rdfs:subClassOf ex:ServiceSchedule .

ex:UnplannedDisruption a owl:Class ;
    rdfs:label "Unplanned Disruption" ;
    rdfs:comment "An unexpected disruption, like a technical fault." ;
    rdfs:subClassOf ex:ServiceDisruption .

ex:affectsRoute a owl:ObjectProperty ;
    rdfs:label "affects route" ;
    rdfs:comment "Links a service disruption to the specific route it is impacting." ;
    rdfs:domain ex:ServiceDisruption ;
    rdfs:range ex:Route .

ex:affectsStop a owl:ObjectProperty ;
    rdfs:label "affects stop" ;
    rdfs:comment "Links a service disruption to a specific station or stop." ;
    rdfs:domain ex:ServiceDisruption ;
    rdfs:range ex:TransitAccessPoint .

ex:appliesDuring a owl:ObjectProperty ;
    rdfs:label "applies during" ;
    rdfs:comment "Links a fare or a service restriction to a specific time window." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ex:Fare ex:Route ) ] ;
    rdfs:range ex:TimeWindow .

ex:belongsToRoute a owl:ObjectProperty ;
    rdfs:label "belongs to route" ;
    rdfs:comment "Links a sequence of stops to the specific route they define." ;
    rdfs:domain ex:RouteStopSequence ;
    rdfs:range ex:Route .

ex:directlyConnectedTo a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "directly connected to" ;
    rdfs:comment "Indicates a direct connection between two transit access points (e.g., adjacent stations)." ;
    rdfs:domain ex:TransitAccessPoint ;
    rdfs:range ex:TransitAccessPoint .

ex:disruptionDate a owl:DatatypeProperty ;
    rdfs:label "disruption date" ;
    rdfs:comment "The date and time when a disruption event occurred.",
        "The date and time when a service disruption occurred." ;
    rdfs:domain ex:ServiceDisruption ;
    rdfs:range xsd:dateTime .

ex:endPoint a owl:ObjectProperty ;
    rdfs:label "end point" ;
    rdfs:comment "The final station or stop of a specific journey." ;
    rdfs:domain ex:Journey ;
    rdfs:range ex:TransitAccessPoint .

ex:endTime a owl:DatatypeProperty ;
    rdfs:label "end time" ;
    rdfs:comment "The conclusion of a time window." ;
    rdfs:domain ex:TimeWindow ;
    rdfs:range xsd:time .

ex:endZone a owl:ObjectProperty ;
    rdfs:label "end zone" ;
    rdfs:comment "The fare zone where a journey concludes." ;
    rdfs:domain ex:Journey ;
    rdfs:range ex:Zone .

ex:expectedCompletionDate a owl:DatatypeProperty ;
    rdfs:label "expected completion date" ;
    rdfs:comment "The anticipated date when the upgrade or expansion will be finished." ;
    rdfs:domain ex:InfrastructureProject ;
    rdfs:range xsd:date .

ex:fareCost a owl:DatatypeProperty ;
    rdfs:label "fare cost" ;
    rdfs:comment "The monetary price of a fare." ;
    rdfs:domain ex:Fare ;
    rdfs:range xsd:decimal .

ex:hasCause a owl:ObjectProperty ;
    rdfs:label "has cause" ;
    rdfs:comment "The underlying reason for a disruption (e.g., strike, fault)." ;
    rdfs:domain ex:ServiceDisruption ;
    rdfs:range ex:DisruptionCause .

ex:hasEndPoint a owl:ObjectProperty ;
    rdfs:label "has end point" ;
    rdfs:comment "The ending point of a specific line segment." ;
    rdfs:domain ex:LineSegment ;
    rdfs:range ex:TransitAccessPoint .

ex:hasFare a owl:ObjectProperty ;
    rdfs:label "has fare" ;
    rdfs:comment "Links a journey to the applicable fare object." ;
    rdfs:domain ex:Journey ;
    rdfs:range ex:Fare .

ex:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:comment "the human-readable name of an entity (e.g., station name, line name)." ;
    rdfs:range xsd:string .

ex:hasOffPeakPeriod a owl:ObjectProperty ;
    rdfs:label "has off-peak period" ;
    rdfs:comment "Links a station or line to its specific off-peak window." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ex:Station ex:Route ) ] ;
    rdfs:range ex:OffPeakPeriod .

ex:hasPeakPeriod a owl:ObjectProperty ;
    rdfs:label "has peak period" ;
    rdfs:comment "Links a station or line to its specific peak demand window." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ex:Station ex:Route ) ] ;
    rdfs:range ex:PeakPeriod .

ex:hasProjectStatus a owl:ObjectProperty ;
    rdfs:label "has project status" ;
    rdfs:comment "Indicates the current lifecycle stage of an infrastructure project." ;
    rdfs:domain ex:InfrastructureProject ;
    rdfs:range ex:ProjectStatus .

ex:hasScheduleType a owl:ObjectProperty ;
    rdfs:label "has schedule type" ;
    rdfs:comment "Links a route or line to its operating schedule category (e.g., 24-hour or Limited)." ;
    rdfs:domain ex:Route ;
    rdfs:range ex:ServiceSchedule .

ex:hasSeverity a owl:ObjectProperty ;
    rdfs:label "has severity" ;
    rdfs:comment "The scale of impact a disruption has on the network." ;
    rdfs:domain ex:ServiceDisruption .

ex:hasStartPoint a owl:ObjectProperty ;
    rdfs:label "has start point" ;
    rdfs:comment "The beginning point of a specific line segment." ;
    rdfs:domain ex:LineSegment ;
    rdfs:range ex:TransitAccessPoint .

ex:hasStatus a owl:ObjectProperty ;
    rdfs:label "has status" ;
    rdfs:comment "The current operational status of the service during a disruption." ;
    rdfs:domain ex:ServiceDisruption ;
    rdfs:range ex:DisruptionStatus .

ex:hasStop a owl:ObjectProperty ;
    rdfs:label "has stop" ;
    rdfs:comment "Links a route to the stations or stops that it serves." ;
    rdfs:domain ex:Route ;
    rdfs:range ex:TransitAccessPoint .

ex:hasTransportMode a owl:ObjectProperty ;
    rdfs:label "has transport mode" ;
    rdfs:comment "Indicates the mode of transport available at an access point (e.g., Tube, Bus)." ;
    rdfs:domain ex:TransitAccessPoint ;
    rdfs:range ex:TransportMode .

ex:hasZone a owl:ObjectProperty ;
    rdfs:label "has zone" ;
    rdfs:comment "Assigns a geographic fare zone to a station or stop." ;
    rdfs:domain ex:TransitAccessPoint ;
    rdfs:range ex:Zone .

ex:isApplicableOnWeekends a owl:DatatypeProperty ;
    rdfs:label "is applicable on weekends" ;
    rdfs:comment "Indicates if the time window or fare applies on Saturdays and Sundays." ;
    rdfs:domain ex:TimeWindow ;
    rdfs:range xsd:boolean .

ex:isNightService a owl:DatatypeProperty ;
    rdfs:label "is night service" ;
    rdfs:comment "Indicates if the service is a night-specific variant (e.g., Night Tube)." ;
    rdfs:domain ex:Route ;
    rdfs:range xsd:boolean .

ex:isPubliclyFunded a owl:DatatypeProperty ;
    rdfs:label "is publicly funded" ;
    rdfs:comment "Indicates if the project is financed by government or public taxes." ;
    rdfs:domain ex:InfrastructureProject ;
    rdfs:range xsd:boolean .

ex:latitude a owl:DatatypeProperty ;
    rdfs:label "latitude" ;
    rdfs:comment "The geographic latitude coordinate of a transit point." ;
    rdfs:domain ex:TransitAccessPoint ;
    rdfs:range xsd:decimal .

ex:longitude a owl:DatatypeProperty ;
    rdfs:label "longitude" ;
    rdfs:comment "The geographic longitude coordinate of a transit point." ;
    rdfs:domain ex:TransitAccessPoint ;
    rdfs:range xsd:decimal .

ex:offersAccessibilityFeature a owl:ObjectProperty ;
    rdfs:label "offers accessibility feature" ;
    rdfs:comment "Links a station to its available accessibility services (e.g., elevators)." ;
    rdfs:domain ex:TransitAccessPoint ;
    rdfs:range ex:AccessibilityFeature .

ex:onRoute a owl:ObjectProperty ;
    rdfs:label "on route" ;
    rdfs:comment "Links a line segment to its parent route." ;
    rdfs:domain ex:LineSegment ;
    rdfs:range ex:Route .

ex:openingDate a owl:DatatypeProperty ;
    rdfs:label "opening date" ;
    rdfs:comment "The historical date a line or station first opened to the public." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ex:Line ex:Station ) ] ;
    rdfs:range xsd:date .

ex:operatingDays a owl:DatatypeProperty ;
    rdfs:label "operating days" ;
    rdfs:comment "Textual description of the days the service is active (e.g., 'Mon-Fri')." ;
    rdfs:domain ex:Route ;
    rdfs:range xsd:string .

ex:operationEndTime a owl:DatatypeProperty ;
    rdfs:label "operation end time" ;
    rdfs:comment "The time a service ends daily operations." ;
    rdfs:domain ex:Route ;
    rdfs:range xsd:time .

ex:operationStartTime a owl:DatatypeProperty ;
    rdfs:label "operation start time" ;
    rdfs:comment "The time a service begins daily operations." ;
    rdfs:domain ex:Route ;
    rdfs:range xsd:time .

ex:projectBudget a owl:DatatypeProperty ;
    rdfs:label "project budget" ;
    rdfs:comment "The estimated financial cost of the infrastructure project." ;
    rdfs:domain ex:InfrastructureProject ;
    rdfs:range xsd:decimal .

ex:reachableFrom a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "reachable from" ;
    rdfs:comment "Indicates a station can be reached from another, potentially across multiple segments." ;
    rdfs:domain ex:TransitAccessPoint ;
    rdfs:range ex:TransitAccessPoint .

ex:sequenceStop a owl:ObjectProperty ;
    rdfs:label "sequence stop" ;
    rdfs:comment "Links a specific position in a route sequence to a transit stop." ;
    rdfs:domain ex:RouteStopSequence ;
    rdfs:range ex:TransitAccessPoint .

ex:servedByRoute a owl:ObjectProperty ;
    rdfs:label "served by route" ;
    rdfs:comment "Links a station or stop to the routes that pass through it." ;
    rdfs:domain ex:TransitAccessPoint ;
    rdfs:range ex:Route .

ex:startPoint a owl:ObjectProperty ;
    rdfs:label "start point" ;
    rdfs:comment "The station or stop where a journey begins." ;
    rdfs:domain ex:Journey ;
    rdfs:range ex:TransitAccessPoint .

ex:startTime a owl:DatatypeProperty ;
    rdfs:label "start time" ;
    rdfs:comment "The beginning of a time window." ;
    rdfs:domain ex:TimeWindow ;
    rdfs:range xsd:time .

ex:startZone a owl:ObjectProperty ;
    rdfs:label "start zone" ;
    rdfs:comment "The fare zone where a journey begins." ;
    rdfs:domain ex:Journey ;
    rdfs:range ex:Zone .

ex:stopSequenceNumber a owl:DatatypeProperty ;
    rdfs:label "stop sequence number" ;
    rdfs:comment "The numerical order of a stop within a route." ;
    rdfs:domain ex:RouteStopSequence ;
    rdfs:range xsd:integer .

ex:targetsInfrastructure a owl:ObjectProperty ;
    rdfs:label "targets infrastructure" ;
    rdfs:comment "Links a project to the specific station or line being improved." ;
    rdfs:domain ex:InfrastructureProject ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( ex:Station ex:Route ) ] .

ex:zoneNumber a owl:DatatypeProperty ;
    rdfs:label "zone number" ;
    rdfs:comment "The identifying number of a fare zone." ;
    rdfs:domain ex:Zone ;
    rdfs:range xsd:integer .

ex:Line a owl:Class ;
    rdfs:label "Line" ;
    rdfs:comment "A named transport line, such as a specific Tube or DLR line." ;
    rdfs:subClassOf ex:Route .

ex:OffPeakPeriod a owl:Class ;
    rdfs:label "Off-Peak Period" ;
    rdfs:comment "Lower-demand travel times where discounted fares typically apply." ;
    rdfs:subClassOf ex:TimeWindow .

ex:PeakPeriod a owl:Class ;
    rdfs:label "Peak Period" ;
    rdfs:comment "High-demand travel times (e.g., morning and evening rush hours) where higher fares often apply." ;
    rdfs:subClassOf ex:TimeWindow .

ex:TrainStation a owl:Class ;
    rdfs:label "Train Station" ;
    rdfs:comment "A station specifically for heavy or light rail services." ;
    rdfs:subClassOf ex:Station .

ex:AccessibilityFeature a owl:Class ;
    rdfs:label "Accessibility Feature" ;
    rdfs:comment "Physical features or services providing access (e.g., step-free access)." .

ex:ProjectStatus a owl:Class ;
    rdfs:label "Project Status" ;
    rdfs:comment "The current stage of a project (e.g., Proposed, Under Construction, Completed)." .

ex:SpatialThing a owl:Class ;
    rdfs:label "Spatial Thing" ;
    rdfs:comment "Anything with a physical location or spatial extent." .

ex:TechnicalFault a owl:Class ;
    rdfs:label "Technical Fault" ;
    rdfs:comment "Mechanical or electronic equipment failure." ;
    rdfs:subClassOf ex:DisruptionCause .

ex:TransportMode a owl:Class ;
    rdfs:label "Transport Mode" ;
    rdfs:comment "The type of vehicle used (e.g., Tube, Bus, DLR)." .

ex:LineSegment a owl:Class ;
    rdfs:label "Line Segment" ;
    rdfs:comment "A specific portion of a transport line between two points." ;
    rdfs:subClassOf ex:SpatialThing .

ex:RouteStopSequence a owl:Class ;
    rdfs:label "Route Stop Sequence" ;
    rdfs:comment "The ordered list of stops that define a specific route." .

ex:DisruptionCause a owl:Class ;
    rdfs:label "Disruption Cause" ;
    rdfs:comment "The underlying reason for a service disruption." .

ex:ServiceSchedule a owl:Class ;
    rdfs:label "Service Schedule" ;
    rdfs:comment "The timeframe and frequency under which a transport service operates." .

ex:Station a owl:Class ;
    rdfs:label "Station" ;
    rdfs:comment "A designated stopping place for trains." ;
    rdfs:subClassOf ex:TransitAccessPoint .

ex:Zone a owl:Class ;
    rdfs:label "Zone" ;
    rdfs:comment "A geographic area used for fare calculation." .

ex:DisruptionStatus a owl:Class ;
    rdfs:label "Disruption Status" ;
    rdfs:comment "The operational state of a line (e.g., Severe Delays)." .

ex:Fare a owl:Class ;
    rdfs:label "Fare" ;
    rdfs:comment "The cost associated with a journey." .

ex:Journey a owl:Class ;
    rdfs:label "Journey" ;
    rdfs:comment "A specific instance of travel from an origin to a destination." .

ex:TimeWindow a owl:Class ;
    rdfs:label "Time Window" ;
    rdfs:comment "A defined period of time during the day used for scheduling or fare calculation." .

ex:InfrastructureProject a owl:Class ;
    rdfs:label "Infrastructure Project" ;
    rdfs:comment "A planned endeavor to improve or expand the transport network." .

ex:ServiceDisruption a owl:Class ;
    rdfs:label "Service Disruption" ;
    rdfs:comment "An event that interferes with normal operation." .

ex:Route a owl:Class ;
    rdfs:label "Route" ;
    rdfs:comment "A path or course followed by a public transport service." .

ex:TransitAccessPoint a owl:Class ;
    rdfs:label "Transit Access Point" ;
    rdfs:comment "A physical location where passengers enter or exit the system." ;
    rdfs:subClassOf ex:SpatialThing .

[] a owl:AllDisjointClasses ;
    owl:members ( ex:TransitAccessPoint ex:Zone ex:TransportMode ex:Journey ex:AccessibilityFeature ex:Fare ex:Route ex:RouteStopSequence ex:ServiceDisruption ex:DisruptionCause ex:DisruptionStatus ex:ServiceSchedule ex:TimeWindow ex:InfrastructureProject ex:ProjectStatus ) .

