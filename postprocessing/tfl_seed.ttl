# =============================================================================
# VICTORIA LINE ROUTE STOP SEQUENCES
# Q3 (Bus Route 25 sequence) + Q4 (Victoria Station adjacency num±1)
# Victoria Station is stop 5: adjacent = Pimlico (4) and Green Park (6)
# =============================================================================

:VL_Seq_01 a owl:NamedIndividual, :RouteStopSequence ;
    :belongsToRoute :Victoria_Line ; :stopSequenceNumber 1 ;
    :sequenceStop :Brixton_Station .

