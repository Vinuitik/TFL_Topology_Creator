# Counter-Q8: no step-free access
:Oval_Station a owl:NamedIndividual, :TrainStation ;
    rdfs:label "Oval Station" ; :hasName "Oval Station" ;
    :hasZone :Zone_2 .

# Counter-Q8: no step-free access
:Kennington_Station a owl:NamedIndividual, :TrainStation ;
    rdfs:label "Kennington Station" ; :hasName "Kennington Station" ;
    :hasZone :Zone_2 .

# Counter-Q1/Q7: Zone 2, served by Bakerloo and Northern — must NOT appear in Victoria Line / Zone 1 queries
:Elephant_Castle_Station a owl:NamedIndividual, :InterchangeStation ;
    rdfs:label "Elephant and Castle Station" ;
