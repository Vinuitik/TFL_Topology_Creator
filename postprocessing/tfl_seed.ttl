    :hasZone :Zone_6 ;
    :offersAccessibilityFeature :Step_Free_Access .

# =============================================================================
# UNDERGROUND LINES
# Counter-Q18: Jubilee, Northern, Bakerloo, Elizabeth have no :hasScheduleType
#              :TwentyFourHourService → appear as "Limited Service" in Q18
# =============================================================================

:Victoria_Line a owl:NamedIndividual, :Line ;
    rdfs:label "Victoria Line" ; :hasName "Victoria Line" ;
    :openingDate "1968-09-01"^^xsd:date ;
    :operationStartTime "05:00:00"^^xsd:time ;
    :operationEndTime "01:30:00"^^xsd:time ;
    :operatingDays "Monday to Saturday" ;
    :hasPeakPeriod :AM_Peak ;
    :hasPeakPeriod :PM_Peak ;
    :hasOffPeakPeriod :Off_Peak_Midday ;
    :hasOffPeakPeriod :Off_Peak_Evening ;
    :hasScheduleType :TwentyFourHourService ;
    :hasStop :Brixton_Station ;
    :hasStop :Stockwell_Station ;
    :hasStop :Vauxhall_Station ;
    :hasStop :Pimlico_Station ;
    :hasStop :Victoria_Station ;
    :hasStop :Green_Park_Station ;
    :hasStop :Oxford_Circus_Station ;
    :hasStop :Warren_Street_Station ;
    :hasStop :Euston_Station ;
    :hasStop :Kings_Cross_St_Pancras_Station ;
    :hasStop :Highbury_And_Islington_Station ;
