:Liverpool_Street_Station a owl:NamedIndividual, :InterchangeStation ;
    rdfs:label "Liverpool Street Station" ; :hasName "Liverpool Street Station" ;
    :hasZone :Zone_1 ;
    :offersAccessibilityFeature :Step_Free_Access .

:Holborn_Station a owl:NamedIndividual, :InterchangeStation ;
    rdfs:label "Holborn Station" ; :hasName "Holborn Station" ;
    :hasZone :Zone_1 .

:Bond_Street_Station a owl:NamedIndividual, :InterchangeStation ;
    rdfs:label "Bond Street Station" ; :hasName "Bond Street Station" ;
    :hasZone :Zone_1 ;
    :offersAccessibilityFeature :Step_Free_Access .

:Paddington_Station a owl:NamedIndividual, :InterchangeStation ;
    rdfs:label "Paddington Station" ; :hasName "Paddington Station" ;
    :hasZone :Zone_1 ;
    :offersAccessibilityFeature :Step_Free_Access .

:Battersea_Power_Station_Station a owl:NamedIndividual, :TrainStation ;
    rdfs:label "Battersea Power Station Station" ;
    :hasName "Battersea Power Station Station" ;
    :hasZone :Zone_1 ;
    :offersAccessibilityFeature :Step_Free_Access .

:Nine_Elms_Station a owl:NamedIndividual, :TrainStation ;
    rdfs:label "Nine Elms Station" ; :hasName "Nine Elms Station" ;
    :hasZone :Zone_1 .

# ── Zone 2 ──────────────────────────────────────────────────────────────────

:Stockwell_Station a owl:NamedIndividual, :InterchangeStation ;
    rdfs:label "Stockwell Station" ; :hasName "Stockwell Station" ;
    :hasZone :Zone_2 .

# Counter-Q8: no step-free access; Counter-Q1 via adjacency (VL stop 1, not Zone 1)
:Brixton_Station a owl:NamedIndividual, :TrainStation ;
