# Models
OLLAMA_ENTITY_MODEL=qwen2.5:1.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Ollama endpoints
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_EMBED_URL=http://ollama:11434/api/embeddings

# Ollama tuning
OLLAMA_TIMEOUT_SEC=3600
OLLAMA_MAX_RETRIES=2
OLLAMA_BACKOFF_SEC=2

# Pipeline tuning
CHUNK_MAX_WORDS=600
ENTITY_SAME_THRESHOLD=0.88

# Services
COREF_SERVICE_HOST=coref-service:50051
REDIS_URL=redis://redis:6379

# HuggingFace cache
HF_HOME=/app/.hf_cache
TRANSFORMERS_CACHE=/app/.hf_cache
