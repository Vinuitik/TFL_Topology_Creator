# Models
OLLAMA_ENTITY_MODEL=qwen2.5:3b
#OLLAMA_ENTITY_MODEL=qwen2.5:1.5b
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Ollama endpoints
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_EMBED_URL=http://ollama:11434/api/embeddings

# Ollama tuning
OLLAMA_TIMEOUT_SEC=3600
OLLAMA_TEMPERATURE=0.3
OLLAMA_SEED=42
OLLAMA_MAX_RETRIES=3

# Pipeline tuning
ALLOW_NEW_ENTITIES=true
CHUNK_MAX_WORDS=600
ENTITY_SAME_THRESHOLD=0.96
CLASSIFY_BATCH_SIZE=8
REBEL_BATCH_SIZE=4
CLASSIFY_KNN_K=3
EMBED_WORKERS=4

# Post-processing deduplication thresholds (lower = more aggressive than construction)
# Construction used ENTITY_SAME_THRESHOLD=0.96 — that was too conservative
POST_ENTITY_SAME_THRESHOLD=0.75
POST_FUZZY_THRESHOLD=88
POST_LABEL_LENGTH_STDDEV=3.0
# Cosine threshold to overrule LLM rejection — set to 1.0 to disable
POST_DEDUP_OVERRULE_COSINE=0.88

# Post-processing LLM — set to a more powerful model without touching OLLAMA_ENTITY_MODEL
# Falls back to OLLAMA_ENTITY_MODEL if not set
POST_LLM_MODEL=qwen2.5:1.5b

# Tighter stddev for property names (object/datatype/annotation) — fewer long outliers removed
POST_PROP_LABEL_STDDEV=2.0

# Relation inference phase thresholds
POST_INFER_COSINE_THRESHOLD=0.65
POST_INFER_BATCH_SIZE=8
POST_PHASE_TIMEOUT_MINS=15
OLLAMA_STREAM_READ_TIMEOUT_SEC=30

# Services
COREF_SERVICE_HOST=coref-service:50051
REDIS_URL=redis://redis:6379

# HuggingFace cache
HF_HOME=/app/.hf_cache
TRANSFORMERS_CACHE=/app/.hf_cache
