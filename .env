# Models
OLLAMA_ENTITY_MODEL=qwen2.5:3b
#OLLAMA_ENTITY_MODEL=qwen2.5:1.5b
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Ollama endpoints
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_EMBED_URL=http://ollama:11434/api/embeddings

# Ollama tuning
OLLAMA_TIMEOUT_SEC=3600
OLLAMA_TEMPERATURE=0.3
OLLAMA_SEED=42
OLLAMA_MAX_RETRIES=3

# Pipeline tuning
ALLOW_NEW_ENTITIES=true
CHUNK_MAX_WORDS=600
ENTITY_SAME_THRESHOLD=0.96
CLASSIFY_BATCH_SIZE=8
REBEL_BATCH_SIZE=4
CLASSIFY_KNN_K=3
EMBED_WORKERS=4

# Post-processing deduplication thresholds (lower = more aggressive than construction)
# Construction used ENTITY_SAME_THRESHOLD=0.96 — that was too conservative
POST_ENTITY_SAME_THRESHOLD=0.75
POST_FUZZY_THRESHOLD=88

# Services
COREF_SERVICE_HOST=coref-service:50051
REDIS_URL=redis://redis:6379

# HuggingFace cache
HF_HOME=/app/.hf_cache
TRANSFORMERS_CACHE=/app/.hf_cache
